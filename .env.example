# Database — get this from neon.tech after creating a project
DATABASE_URL="postgres://user:password@host/database?sslmode=require"

# NextAuth — generate a secret with: openssl rand -base64 32
# Or use any random 32+ character string
AUTH_SECRET="your-secret-here-make-it-long-and-random"

# The URL of your deployed app. For local dev: http://localhost:3000
# For Vercel: https://your-app.vercel.app
AUTH_URL="http://localhost:3000"

# A secret token to protect the cron endpoint
# Generate another random string for this
CRON_SECRET="another-random-secret-for-cron-jobs"

# Set to "true" if you want new signups disabled (only invited users can join)
DISABLE_PUBLIC_SIGNUP="false"
